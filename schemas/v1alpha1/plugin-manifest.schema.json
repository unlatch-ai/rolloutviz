{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rolloutviz.dev/schemas/v1alpha1/plugin-manifest.schema.json",
  "title": "RolloutViz plugin manifest",
  "type": "object",
  "required": ["api_version", "kind", "name", "version", "command", "capabilities"],
  "properties": {
    "api_version": { "const": "rolloutviz.dev/v1alpha1" },
    "kind": { "enum": ["Adapter"] },
    "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$" },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["adapter.probe", "adapter.stream"] }
    },
    "description": { "type": "string" }
  },
  "additionalProperties": false
}
